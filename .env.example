# HMS Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# OpenClaw Gateway URL (default: http://127.0.0.1:18789)
HMS_GATEWAY_URL=http://127.0.0.1:18789

# OpenClaw Gateway Auth Token (get from openclaw.json)
HMS_GATEWAY_TOKEN=your_gateway_token_here

# LLM Model to use (default: openclaw — routes through Gateway)
HMS_LLM_MODEL=openclaw
