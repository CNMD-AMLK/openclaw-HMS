{
  "_comment": "HMS v4 Plugin Integration — Example openclaw.json section",
  "_doc": "Add this to your openclaw.json plugins.entries section",
  "_note": "HMS v4.0 零外部记忆依赖：自带本地文件存储降级，不依赖 memory-lancedb 等插件",

  "plugins": {
    "entries": {
      "hms-memory": {
        "path": "/path/to/openclaw-HMS",
        "config": {
          "perception_mode": "lite",
          "context_tier": "auto",
          "embedding_model": "local",
          "token_budget_daily": 50000,
          "collision_threshold": 0.7,
          "consolidate_interval": "0 3 * * *",
          "forget_interval": "0 4 * * 0",
          "gateway_url": "http://127.0.0.1:18789"
        }
      }
    }
  }
}
